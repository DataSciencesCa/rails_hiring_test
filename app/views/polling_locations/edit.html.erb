<%= turbo_frame_tag dom_id(@polling_location, params[:attribute]) do %>
  <%= form_with model: [@riding, @polling_location], data: { turbo_frame: "_top" } do |form| %>
    <% if params[:attribute] == "title" %>
        <div>
            <%= form.text_field :title, id: dom_id(@polling_location, :title) %>
        </div>
    <% end %>

    <% if params[:attribute] == "address" %>
        <div>
            <%= form.text_field :address, id: dom_id(@polling_location, :address) %>
        </div>
    <% end %>

    <% if params[:attribute] == "city" %>
        <div>
            <%= form.text_field :city, id: dom_id(@polling_location, :city) %>
        </div>
    <% end %>  

    <% if params[:attribute] == "postal_code" %>
        <div>
            <%= form.text_field :postal_code, id: dom_id(@polling_location, :postal_code) %>
        </div>
    <% end %>    

    <div>
      <%= form.submit 'Save' %>
    </div>
  <% end %>
<% end %>